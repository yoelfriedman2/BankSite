# Copy this file to .env.local and fill in real values. Required/optional as
# noted per line — see README.md for where to get each one.

# Supabase (Dashboard -> Project Settings -> API) — required.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-anon-public-key
# Service-role key (Dashboard -> Project Settings -> API) — required for
# server-side admin operations (shared-field propagation, FDIC sync, backups,
# cron jobs). Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-service-role-key

# The owner's login email — grants owner-only access (Admin pages, FDIC sync
# apply, etc). Required; unset silently means "no owner" and disables every
# owner-gated feature rather than erroring.
ADMIN_EMAIL=you@example.com

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` when
# calling /api/cron/reminders and /api/keepalive. Required for those routes —
# both fail closed (401) if this is unset.
CRON_SECRET=a-long-random-string

# Resend (resend.com) — required for any outbound email (reminders, backups,
# community-note broadcasts, access requests). If unset, sends are skipped
# with a console warning rather than erroring.
RESEND_API_KEY=re_your_api_key
RESEND_FROM=Bank Tracker <notifications@yourdomain.com>

# Public site URL, used to build links inside emails. Optional — defaults to
# https://banktracker.app if unset.
NEXT_PUBLIC_APP_URL=https://your-deployed-url.example.com

# Sentry DSN for error tracking. Optional — Sentry is disabled entirely if unset.
NEXT_PUBLIC_SENTRY_DSN=

# Set to "true" locally to run the whole app against in-memory fake data with
# auth bypassed (the only way to click-test the UI without real Supabase
# credentials). Never honored on the live Vercel production deployment even
# if left set by mistake. Leave unset/false for a real Supabase-backed run.
DEMO_MODE=false
